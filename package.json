{
  "name": "omnichannel-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:main-api": "bun run --cwd apps/main-api dev",
    "dev:wa-adapter": "bun run --cwd apps/wa-adapter dev",
    "dev:email-adapter": "bun run --cwd apps/email-adapter dev",
    "dev:telegram-adapter": "bun run --cwd apps/telegram-adapter dev",
    "test:main-api": "bun test --cwd apps/main-api",
    "test:wa-adapter": "bun test --cwd apps/wa-adapter",
    "test:frontend": "bun run --cwd apps/frontend test",
    "test": "bun run test:main-api && bun run test:wa-adapter && bun run test:frontend"
  }
}