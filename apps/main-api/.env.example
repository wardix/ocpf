# Database Configuration (PostgreSQL)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgres://user:password@localhost:5432/omnichannel

# Redis / Valkey Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# API Configuration
PORT=8000

# Security (Wajib diisi, aplikasi akan crash jika kosong)
JWT_SECRET=ubah_dengan_string_rahasia_acak_yang_panjang
